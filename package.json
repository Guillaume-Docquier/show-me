{
  "name": "@guillaume-docquier/show-me",
  "version": "0.0.1",
  "bin": {
    "show-me": "./dist/cli/entry.cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm build:node && pnpm build:browser",
    "build:browser": "esbuild src/report/browser/entry.browser.ts --bundle --format=iife --target=es2022 --outfile=dist/report/browser.js",
    "build:node": "tsc --project tsconfig.build.json",
    "checks": "pnpm format:fix && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm test:browser",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "lint": "oxlint --max-warnings 0",
    "lint:fix": "pnpm lint --fix",
    "prepack": "pnpm build",
    "prepare": "husky",
    "test": "vitest run --silent",
    "test:browser": "playwright test",
    "test:coverage": "pnpm test --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@guillaume-docquier/tools-ts": "^6.3.1",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "ignore": "^7.0.6",
    "sigma": "^3.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{md,json,yml,yaml,css,scss}": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.11.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "26.5.0",
      "onFail": "download"
    }
  }
}
